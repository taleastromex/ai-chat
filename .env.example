# AI-FABLE configuration
#
# This file is entirely OPTIONAL — docker-compose.yml has working defaults
# for every variable below and will run fine with no .env file at all.
# Copy it only if you want to override something:
#   cp .env.example .env

# GGUF quantization to run via Ollama. See README for size/quality tradeoffs.
OLLAMA_MODEL=hf.co/mradermacher/Huihui-gemma-4-12B-coder-fable5-composer2.5-v1-abliterated-GGUF:Q4_K_M

# Port the web UI / API is exposed on (host side).
PORT=8080

# Port Ollama's own API is exposed on (host side) — rarely needs changing.
OLLAMA_PORT=11434

LOG_LEVEL=INFO

# How many of the most recent chat messages to resend to the model as context
# on every turn (the chat's system prompt, if any, is always included on top
# of this). Higher = more context but slower/costlier requests.
CHAT_HISTORY_LIMIT=20

# ── Only relevant for run_local.sh (native macOS, no Docker) ────────────────
# Docker deployments always talk to Ollama via the internal service name
# "http://ollama:11434" automatically — this line has no effect there.
OLLAMA_HOST=http://localhost:11434
